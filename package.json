    "dev": "concurrently --names \"API,WEB\" --prefix-colors \"cyan,magenta\" \"npm run dev --prefix backend\" \"npm run dev --prefix frontend\"",

    "start-all": "concurrently --names \"API,WEB\" --prefix-colors \"cyan,magenta\" \"npm run start-all:backend\" \"npm run start-all:frontend\"",
    "start-all:backend": "npm run build --prefix backend && npm run start --prefix backend",
    "start-all:frontend": "npm run build --prefix frontend && npm run start --prefix frontend"
